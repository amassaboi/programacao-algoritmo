#include <iostream>
using namespace std;

int main() {
    // Otimizando as operações de entrada e saída
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int N;
    cin >> N;

    int t = 0;

    int inicio[101] = {0};
    int soma[101] = {0};
    bool ativo[101] = {false};
    bool visitado[101] = {false}; // Para rastrear quem participou

    for (int i = 0; i < N; i++) {
        char op;
        int x;
        cin >> op >> x;

        t++; // cada comando passa 1 unidade de tempo

        if (op == 'T') {
            t += x;
        }
        else if (op == 'R') {
            inicio[x] = t;
            ativo[x] = true;
            visitado[x] = true;
        }
        else if (op == 'E') {
            if (ativo[x]) {
                soma[x] += t - inicio[x];
                ativo[x] = false;
            }
        }
    }

    for (int i = 1; i <= 100; i++) {
        // Imprime se o aluno entrou no laboratório pelo menos uma vez
        if (visitado[i]) {
            cout << i << " ";
            if (ativo[i]) {
                cout << -1 << "\n";
            } else {
                cout << soma[i] << "\n";
            }
        }
    }

    return 0;
}
