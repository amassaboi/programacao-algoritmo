#include <iostream>
#include <cmath>
using namespace std;

double areaCirculo(double raio) {
    const double PI = 3.14159265359;
    return PI * raio * raio;
}

int main() {
    double raio;
    double soma = 0;

    for (int i = 0; i < 5; i++) {
        cin >> raio;
        soma += areaCirculo(raio);
    }

    cout << "Soma das areas: " << soma << endl;

    return 0;
}
