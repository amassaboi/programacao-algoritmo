#include <iostream>
using namespace std;

int potencia(int base, int expoente) {
    int resultado = 1;

    for (int i = 0; i < expoente; i++) {
        resultado *= base;
    }

    return resultado;
}

int main() {
    int base, expoente;

    cin >> base >> expoente;

    cout << potencia(base, expoente);

    return 0;
}
