#include <iostream>
using namespace std;

int main() {
    char letras[20];
    char procurada;
    int contador = 0;

    for (int i = 0; i < 20; i++) {
        cin >> letras[i];
    }

    cin >> procurada;

    for (int i = 0; i < 20; i++) {
        if (letras[i] == procurada) {
            contador++;
        }
    }

    cout << "Quantidade: " << contador << endl;

    return 0;
}
