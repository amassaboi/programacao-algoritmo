#include <iostream>
using namespace std;

int main() {
    int limite;
    int multiplo;

    cout << "Digite o numero final: ";
    cin >> limite;

    cout << "Digite o numero multiplo: ";
    cin >> multiplo;

    if (multiplo == 0) {
        cout << "Multiplo invalido!" << endl;
        return 0;
    }

    cout << "Multiplos de " << multiplo << " ate " << limite << ":" << endl;

    for (int i = 1; i <= limite; i++) {

        if (i % multiplo == 0) {
            cout << i << endl;
        }

    }

    return 0;
}
