#include <iostream>
using namespace std;

string verificarOrdem(int v[], int tamanho) {
    bool crescente = true;
    bool decrescente = true;

    for (int i = 0; i < tamanho - 1; i++) {
        if (v[i] >= v[i + 1])
            crescente = false;

        if (v[i] <= v[i + 1])
            decrescente = false;
    }

    if (crescente)
        return "Crescente";
    else if (decrescente)
        return "Decrescente";
    else
        return "Nao ordenado";
}

int main() {
    int numeros[5];

    for (int i = 0; i < 5; i++) {
        cin >> numeros[i];
    }

    cout << verificarOrdem(numeros, 5);

    return 0;
}
