#include <iostream>
using namespace std;

double masculino(double altura) {
    return 72.7 * altura - 58;
}

double feminino(double altura) {
    return 62.1 * altura - 44.7;
}

int main() {
    char sexo;
    double altura;

    cin >> sexo >> altura;

    if (sexo == 'M' || sexo == 'm')
        cout << masculino(altura);
    else
        cout << feminino(altura);

    return 0;
}
