#include <iostream>
using namespace std;

int inicio[102];
int total_tempo[102];
bool ativo[102];
bool visitado[102];

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int N;
    cin >> N;

    int t = 0;

    for (int i = 0; i < N; i++) {
        char op;
        int x;
        cin >> op >> x;

        if (op == 'T') {
            t += x;
        }
        else if (op == 'R') {
            inicio[x] = t;
            ativo[x] = true;
            visitado[x] = true;
            t++;
        }
        else if (op == 'E') {
            if (ativo[x]) {
                total_tempo[x] += t - inicio[x];
                ativo[x] = false;
            }
            t++;
        }
    }

    for (int i = 1; i <= 100; i++) {
        if (visitado[i]) {
            cout << i << " ";
            if (ativo[i])
                cout << -1 << '\n';
            else
                cout << total_tempo[i] << '\n';
        }
    }

    return 0;
}
