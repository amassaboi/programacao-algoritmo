#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Digite um número: ";
    cin >> n;

    if (n < 2) {
        cout << "não é primo." << endl;
        return 0;
    }

    bool primo = true;

    for (int i = 2; i < n; i++) {
        if (n % i == 0) {
            primo = false;
            break;
        }
    }

    if (primo) {
        cout << "é primo." << endl;
    } else {
        cout << "não é primo." << endl;
    }

    return 0;
}
