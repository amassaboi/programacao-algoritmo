#include <iostream>
using namespace std;

int main() {
    int n;
    int soma = 0;

    // Mensagem explicativa para o usuário
    cout << "Digite numeros positivos para somar ou um numero negativo para encerrar:" << endl;

    while (true) {
        cin >> n;
        
        if (n < 0) {
            break; // Encerra o loop se o número for negativo
        }
        
        soma += n; // Adiciona o número positivo à soma
    }

    // Correção das aspas para exibir o texto corretamente
    cout << "Soma = " << soma << endl;

    return 0;
}
