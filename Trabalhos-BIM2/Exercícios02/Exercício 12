#include <iostream>
using namespace std;

int main() {
    int vetor[15];
    int pares = 0;
    int impares = 0;

    for (int i = 0; i < 15; i++) {
        cin >> vetor[i];

        if (vetor[i] % 2 == 0)
            pares++;
        else
            impares++;
    }

    cout << "Pares: " << pares << endl;
    cout << "Impares: " << impares << endl;

    return 0;
}
